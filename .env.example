# ============================================================
# Agent Template 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# 运行环境: development / production
AGENT_ENV=development

# ---------- LLM ----------
# DashScope (通义千问)
AGENT_LLM_API_KEY=your-dashscope-api-key

# 如需使用 OpenAI 兼容接口 (DeepSeek/GLM/Ollama)，修改 settings.yaml 中的 provider

# ---------- RAG ----------
AGENT_RAG_EMBEDDING_API_KEY=your-embedding-api-key

# ---------- Redis ----------
# AGENT_MEMORY_REDIS_URL=redis://localhost:6379/0
